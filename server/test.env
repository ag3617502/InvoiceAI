# Back-End Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/invoiceai

# JWT Authentication Configuration
JWT_ACCESS_SECRET=a_very_long_and_random_string_for_access_token_secret_invoiceai
JWT_REFRESH_SECRET=a_very_long_and_random_string_for_refresh_token_secret_invoiceai
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookie Security (Set to true in production)
COOKIE_SECURE=false
COOKIE_DOMAIN=localhost

# Client (Frontend) URL for CORS
CLIENT_URL=http://localhost:5174

# AI Integrations (Add your API Keys here)
GROQ_API_KEY=gsk_your_groq_api_key_placeholder
GEMINI_API_KEY=AIza_your_gemini_api_key_placeholder
